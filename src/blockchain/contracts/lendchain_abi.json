[
  {
    "type": "constructor",
    "inputs": [
      { "name": "_usdc",          "type": "address" },
      { "name": "_borrower",      "type": "address" },
      { "name": "_amountUsdc",    "type": "uint256" },
      { "name": "_termMonths",    "type": "uint256" },
      { "name": "_annualRateBps", "type": "uint256" },
      { "name": "_lender",        "type": "address" }
    ],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "fundLoan",
    "inputs": [],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "makePayment",
    "inputs": [
      { "name": "amount", "type": "uint256" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "getState",
    "inputs": [],
    "outputs": [
      { "name": "_status",      "type": "uint8"   },
      { "name": "_totalRepaid", "type": "uint256" },
      { "name": "_fundedAt",    "type": "uint256" },
      { "name": "_amountUsdc",  "type": "uint256" }
    ],
    "stateMutability": "view"
  },
  {
    "type": "event",
    "name": "LoanCreated",
    "anonymous": false,
    "inputs": [
      { "name": "borrower",   "type": "address", "indexed": true  },
      { "name": "amount",     "type": "uint256", "indexed": false },
      { "name": "termMonths", "type": "uint256", "indexed": false }
    ]
  },
  {
    "type": "event",
    "name": "LoanFunded",
    "anonymous": false,
    "inputs": [
      { "name": "lender",   "type": "address", "indexed": true  },
      { "name": "amount",   "type": "uint256", "indexed": false },
      { "name": "fundedAt", "type": "uint256", "indexed": false }
    ]
  },
  {
    "type": "event",
    "name": "PaymentMade",
    "anonymous": false,
    "inputs": [
      { "name": "borrower",    "type": "address", "indexed": true  },
      { "name": "amount",      "type": "uint256", "indexed": false },
      { "name": "totalRepaid", "type": "uint256", "indexed": false }
    ]
  },
  {
    "type": "event",
    "name": "LoanClosed",
    "anonymous": false,
    "inputs": [
      { "name": "closedAt", "type": "uint256", "indexed": false }
    ]
  }
]
